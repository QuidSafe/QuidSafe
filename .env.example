# ─── QuidSafe Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env - it contains secrets.

# ─── General ──────────────────────────────────────────────
# Environment name: "development", "staging", or "production"
ENVIRONMENT=development

# ─── Clerk (Authentication) ──────────────────────────────
# Clerk secret key for backend JWT verification (from Clerk dashboard)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Clerk publishable key (from Clerk dashboard, also used in wrangler.toml vars)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── Stripe (Payments) ───────────────────────────────────
# Stripe secret key for server-side API calls
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Stripe webhook signing secret for verifying webhook payloads
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── TrueLayer (Open Banking) ────────────────────────────
# TrueLayer OAuth client ID (from TrueLayer console)
TRUELAYER_CLIENT_ID=your-truelayer-client-id
# TrueLayer OAuth client secret
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
# Redirect URI for TrueLayer OAuth flow (must match TrueLayer console config)
TRUELAYER_REDIRECT_URI=http://localhost:8787/api/banking/callback
# Native deep link redirect (used when platform=native)
TRUELAYER_REDIRECT_URI_NATIVE=quidsafe://banking/callback
# Web redirect (same as TRUELAYER_REDIRECT_URI for local dev)
TRUELAYER_REDIRECT_URI_WEB=http://localhost:8787/api/banking/callback

# ─── HMRC (Making Tax Digital) ───────────────────────────
# HMRC API client ID for MTD integration
HMRC_CLIENT_ID=your-hmrc-client-id
# HMRC API client secret
HMRC_CLIENT_SECRET=your-hmrc-client-secret
# Redirect URI for HMRC OAuth flow
HMRC_REDIRECT_URI=http://localhost:8787/mtd/callback
# Native deep link redirect (used when platform=native)
HMRC_REDIRECT_URI_NATIVE=quidsafe://hmrc/callback
# Web redirect
HMRC_REDIRECT_URI_WEB=http://localhost:8787/api/hmrc/callback

# ─── Encryption ──────────────────────────────────────────
# AES-256-GCM key for encrypting bank tokens at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-string

# ─── AI (Claude) ─────────────────────────────────────────
# Anthropic API key for transaction categorisation via Claude Haiku
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare (CI/CD and infrastructure) ───────────────
# Used in GitHub Actions workflows and wrangler CLI
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# D1 database ID (see wrangler.toml for per-environment IDs)
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id

# ─── Expo Frontend (public, prefixed with EXPO_PUBLIC_) ──
# API base URL for the frontend to call
EXPO_PUBLIC_API_URL=http://localhost:8787
# Clerk publishable key for frontend auth
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Stripe publishable key for frontend payment UI
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
