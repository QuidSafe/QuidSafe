{
  "name": "quidsafe",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "worker:dev": "wrangler dev --config wrangler.worker.toml",
    "worker:deploy": "wrangler deploy --config wrangler.worker.toml",
    "worker:deploy:staging": "wrangler deploy --env staging --config wrangler.worker.toml",
    "worker:deploy:production": "wrangler deploy --env production --config wrangler.worker.toml",
    "d1:migrate:local": "wrangler d1 migrations apply quidsafe-dev --local --config wrangler.worker.toml",
    "d1:migrate:dev": "wrangler d1 migrations apply quidsafe-dev --remote --config wrangler.worker.toml",
    "d1:migrate:staging": "wrangler d1 migrations apply quidsafe-staging --remote --config wrangler.worker.toml --env staging",
    "d1:migrate:production": "wrangler d1 migrations apply quidsafe-production --remote --config wrangler.worker.toml --env production",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/lexend": "^0.4.1",
    "@expo-google-fonts/source-sans-3": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.96.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "hono": "^4.12.10",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.4"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/react": "~19.1.0",
    "eslint": "^9.17.0",
    "eslint-config-expo": "~9.1.0",
    "prettier": "^3.4.2",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
